# ============================================
# BlackSwan AI Backend - Environment Configuration
# For IBM Cloud Code Engine Deployment
# ============================================

# Application Configuration
APP_NAME=BlackSwan AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# API Configuration
API_V1_PREFIX=/api/v1

# CORS Configuration
# For production, set to your frontend URL(s)
# Examples:
# - Single origin: https://your-frontend.example.com
# - Multiple origins: ["https://your-frontend.example.com","https://www.example.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Server Configuration
HOST=0.0.0.0
PORT=8000

# IBM watsonx.ai Configuration
# REQUIRED for AI-powered intelligence
# Get credentials from: https://cloud.ibm.com/
# 1. Create IBM Cloud account
# 2. Create watsonx.ai project
# 3. Get API key from IAM (Identity and Access Management)
# 4. Get project ID from watsonx.ai project settings
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# OpenAI Configuration (Optional - for development/testing)
OPENAI_API_KEY=sk-placeholder-key-for-local-dev
OPENAI_MODEL=gpt-4-turbo-preview

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database Configuration (Optional - for persistence)
DATABASE_URL=postgresql+asyncpg://user:password@localhost/blackswan

# Agent Configuration
MAX_AGENT_RETRIES=3
AGENT_TIMEOUT=300
MAX_CONCURRENT_AGENTS=5

# Made with Bob